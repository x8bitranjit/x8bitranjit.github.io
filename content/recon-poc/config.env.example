# =============================================================================
#  x8bit_recon — config.env   (API keys + optional tunables)
# =============================================================================
#  HOW IT WORKS
#    • Every key below is OPTIONAL.
#        - key MISSING  -> that one source is skipped; the rest of the run is
#                          unaffected and still produces full results.
#        - key PRESENT  -> x8bit_recon picks it up automatically for deeper
#                          coverage (more subdomains / ASN data / etc.).
#    • So you can run with an EMPTY file and everything still works. Fill in
#      whatever keys you have, over time — each one only adds coverage.
#
#  SETUP
#      cp config.env.example config.env      # then edit config.env
#    The script auto-loads ./config.env (next to x8bit_recon.sh). Use a file
#    somewhere else with:   X8_CONFIG=/path/to/config.env ./x8bit_recon.sh tgt
#
#  SECURITY
#    • config.env holds secrets — do NOT commit it / share it. (config.env is
#      git-ignored; only this *.example template is tracked.)
#    • Quote values with special chars:  KEY="abc/def+ghi="
#    • Windows-edited (Notepad)? Fine — trailing CRLF is stripped on load.
# =============================================================================


# ── ProjectDiscovery (PDCP) ─────────────────────────────────────────────────
#   ONE free key unlocks several PD tools at once:
#     • asnmap  → ASN / CIDR ranges (WITHOUT this key asnmap only hangs on a
#                 prompt, so the ASN phase is skipped entirely until you set it)
#     • chaos   → large passive subdomain dataset
#     • nuclei  → optional cloud features
#   Get it free:  https://cloud.projectdiscovery.io  →  Settings → API Key
#   (or run `pdcp -auth` once in your shell and it stores the key for you).
PDCP_API_KEY=""

# Standalone Chaos key (only if you use a separate one; otherwise PDCP_API_KEY
# above is used for chaos automatically).
CHAOS_KEY=""


# ── Subdomain OSINT providers (subfinder) ───────────────────────────────────
#   subfinder works WITHOUT any of these (free sources: crt.sh, etc.). Each key
#   you add turns on another data source → more subdomains. All free-tier.
VIRUSTOTAL_API_KEY=""        # https://www.virustotal.com  (free: API key in profile)
SECURITYTRAILS_API_KEY=""    # https://securitytrails.com  (free tier)
SHODAN_API_KEY=""            # https://account.shodan.io
BEVIGIL_API_KEY=""           # https://bevigil.com/osint-api
BINARYEDGE_API_KEY=""        # https://app.binaryedge.io
FOFA_KEY=""                  # https://fofa.info
CENSYS_API_ID=""             # https://search.censys.io/account/api  (needs BOTH
CENSYS_API_SECRET=""         #  id + secret to be enabled)


# ── GitHub ──────────────────────────────────────────────────────────────────
#   A classic (read-only, no-scope) PAT enables github-based subdomain/secret
#   sources and lifts gau/github rate limits. https://github.com/settings/tokens
GITHUB_TOKEN=""


# ── Optional tunables ────────────────────────────────────────────────────────
#   Leave COMMENTED to keep command-line env (e.g. `RATE=40 ./x8bit_recon.sh …`)
#   in control. Uncomment to bake in a personal default.
# RATE=150            # httpx / nuclei requests-per-second (politeness)
# PUREDNS_RATE=150    # DNS brute qps — keep low on WSL (NAT conntrack), raise on native Linux
# PASSIVE_ONLY=0      # 1 = OSINT-only (skip brute / port-scan / dalfox)
